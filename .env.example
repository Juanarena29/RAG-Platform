ENVIRONMENT=dev
DEBUG=true

DATABASE_URL=sqlite:///./rag_platform.db

CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]
DEFAULT_RATE_LIMIT=60/minute
QUERY_RATE_LIMIT=200/hour #200/hour para testing

POSTGRES_DB=rag_platform
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=

OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

USE_HYDE_DEFAULT=true
USE_QUERY_TRANSFORM_DEFAULT=true
RERANKER_TYPE=local
COHERE_API_KEY=
GENERATOR_MODEL=gpt-4o-mini
OPENAI_CHAT_INPUT_PRICE_PER_1M=0.15
OPENAI_CHAT_OUTPUT_PRICE_PER_1M=0.60
OPENAI_EMBEDDING_PRICE_PER_1M=0.02
RETRIEVER_TOP_K=20
RERANKER_TOP_N=5

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# RAGAS eval (backend/tests/eval_ragas.py) — optional, loaded from repo-root .env
EVAL_API_KEY=
BASE_URL=http://localhost:8000
